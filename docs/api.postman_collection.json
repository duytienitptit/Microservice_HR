        {
          "name": "HR Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data) {",
                  "    if (jsonData.data.accessToken) {",
                  "        pm.environment.set(\"jwt_token\", jsonData.data.accessToken);",
                  "        console.log(\"Saved jwt_token environment variable\");",
                  "    }",
                  "    if (jsonData.data.refreshToken) {",
                  "        pm.environment.set(\"refresh_token\", jsonData.data.refreshToken);",
                  "        console.log(\"Saved refresh_token environment variable\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
